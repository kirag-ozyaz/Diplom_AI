# чистка кэша игнора
# 1. Убираем из индекса Git ВСЕ файлы (но оставляем на диске!)
# git rm -r --cached .
# 2. Добавляем файлы обратно (те, что не игнорируются) 
# git add .
# 3. Проверяем статус - файлы с точкой должны быть в "Untracked files"
# git status
# 4. Фиксируем изменения
# git commit -m "fix: update gitignore"
# Игнорим все что с точек начинается
.*
!.gitignore
!.github/
!.gitlab-ci.yml
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Docker
docker-compose.override.yml

# Milvus data (если храните локально)
milvus/data/
milvus/logs/
infra/milvus/volume/
infra/milvus/volumes/

# Vector DB data
data/embeddings/
*.db
*.sqlite3
chroma.sqlite3

# Telegram
*.session
*.session-journal

# Temporary files
*.tmp
*.bak
*.log

# OS
Thumbs.db
.DS_Store

# Если хотите игнорировать папки с черновиками
# trash/
# trash_2/

# Jupyter Notebook контрольные точки уже игнорируются правилом .*
.ipynb_checkpoints/
**/.ipynb_checkpoints/
